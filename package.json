{
  "name": "@hienfeld/design-system",
  "version": "0.1.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hienfeld/design-system.git"
  },
  "type": "module",
  "main": "dist/hienfeld-design-system.cjs",
  "module": "dist/hienfeld-design-system.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/hienfeld-design-system.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/hienfeld-design-system.cjs"
      }
    },
    "./styles.css": "./dist/hienfeld-design-system.css",
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build && vite build --config vite.config.tokens.ts && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "storybook": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@chromatic-com/storybook": "^5.0.2",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-onboarding": "^10.3.1",
    "vitest": "^4.1.0",
    "playwright": "^1.58.2",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  }
}
